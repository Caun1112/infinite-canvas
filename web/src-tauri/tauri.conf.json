{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InfiniteCanvas",
  "version": "0.2.5",
  "identifier": "com.caun1112.infinitecanvas",
  "build": {
    "frontendDist": "../app-shell",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "无限画布",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/macos"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
